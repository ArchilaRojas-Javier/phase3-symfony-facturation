<div class='flex flex-col gap-2 bg-white p-6 rounded-md shadow-sm'>
	<h1 class=' text-2xl font-bold text-black'>{{ form_title|default('Nouveau Client') }}</h1>
	<p class='text-gray-500'>{{ form_label|default('') }}</p>
	{{ form_start(form) }}
	    {{ form_label(form.name) }}
	    {{ form_widget(form.name, {attr: {class: 'w-full h-10 mb-2 border rounded-md border-gray-200 rounded-md'}}) }}
	    {{ form_errors(form.name) }}


        <div class='flex gap-1'>
            <div class='flex flex-col w-1/2'>
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {attr: {class: ' w-full h-10 mb-2 border rounded-md border-gray-200 rounded-md'}}) }}
                {{ form_errors(form.email) }}
            </div>
            <div class='flex flex-col w-1/2'>
                {{ form_label(form.phone) }}
                {{ form_widget(form.phone, {attr: {class: ' w-full h-10 mb-2 border rounded-md border-gray-200 rounded-md'}}) }}
                {{ form_errors(form.phone) }}
            </div>
        </div>

	    {{ form_label(form.address) }}
	    {{ form_widget(form.address, {attr: {class: ' w-full h-20 mb-2 border rounded-md border-gray-200 rounded-md'}}) }}
	    {{ form_errors(form.address) }}

        <div class='flex gap-1'>
            <div class='flex flex-col w-1/2'>
                {{ form_label(form.siret) }}
                {{ form_widget(form.siret, {attr: {class: ' w-full h-10 mb-2 border rounded-md border-gray-200 rounded-md'}}) }}
                {{ form_errors(form.siret) }}
            </div>
            <div class='flex flex-col w-1/2'>
                {{ form_label(form.iban) }}
                {{ form_widget(form.iban, {attr: {class: ' w-full h-10 mb-2 border rounded-md border-gray-200 rounded-md'}}) }}
                {{ form_errors(form.iban) }}
            </div>
        </div>

        <div class='flex gap-4 mt-6 justify-end'>
            <button class="btn bg-white text-black border border-gray-200 h-10 p-2 rounded-md">
                <a href="{{ path('app_client_index') }}">Annuler</a>
            </button>
            <button type="submit" class="btn btn bg-blue-500 text-white h-10 p-2 rounded-md">
                {{ button_label|default('Enregistrer') }}
            </button>
        </div>
	{{ form_end(form) }}
</div>
