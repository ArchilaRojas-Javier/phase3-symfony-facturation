<section class='flex flex-col bg-white h-screen w-2xs text-gray-600 border-r border-r-gray-200' >


	<div class='flex items-center justify-center gap-2  p-6 h-1/10'>
		<twig:ux:Icon name="lucide:receipt" class="w-5 h-5 text-[#155DFC]"/>
		<h1 class="text-lg font-bold text-blue-600	">FacturSaaS</h1>
	</div>
	<div class='flex flex-col gap-2 px-4 py-2 h-8/10 border-b border-gray-200'>
		<a href="{{ path('app_dashboard') }}" class="flex items-center gap-2 hover:text-blue-600 hover:bg-blue-100 rounded-md px-2 py-1">
			{{ ux_icon('lucide:home') }}
			<span>Dashboard</span>
		</a>
		{# <a href="{{ path('app_invoices') }}" class="flex items-center gap-2 hover:text-blue-600"> #}
		{{ ux_icon('lucide:file-text') }}
		<span>Factures</span>
		</a>
		{# <a href="{{ path('app_customers') }}" class="flex items-center gap-2 hover:text-blue-600"> #}
		{{ ux_icon('lucide:users') }}
		<span>Clients</span>
		</a>
		<a href="{{ path('app_product_index') }}" class="flex items-center gap-2 hover:text-blue-600 hover:bg-blue-100 rounded-md px-2 py-1"> 
		{{ ux_icon('lucide:box') }}
		<span>Produits</span>
		</a>
		<a href="{{ path('app_profile') }}" class="flex items-center gap-2 hover:text-blue-600 hover:bg-blue-100 rounded-md px-2 py-1 "> 
		{{ ux_icon('lucide:settings') }}
		Profil
		</a>
	</div>
	<div class='flex flex-col items-center gap-6 py-6 h-2/10'>
		<div class="flex items-center gap-4">
			<div class='aspect-square w-16 rounded-full bg-blue-300 flex items-center justify-center text-gray-600 text-xl font-bold'>
				<p>
				{{ app.user.firstName|slice(0,1) }}{{ app.user.lastName|slice(0,1) }}
				</p>
			</div>
			{% set email, company = app.user.email, app.user.companyName %}
			<div class="flex flex-col items-center gap-1">
				<h2>{{ company }}</h2>
				<p>{{ email }}</p>
			
			</div>
		</div>
			<button class="flex items-center gap-2 text-red-500 hover:text-red-700 text-2xl">
				{{ ux_icon('lucide:log-out') }}
				<a href="{{ path('app_logout') }}">Deconnexion</a>
			</button>
	</div>
</section>
