<div class='flex flex-col gap-2 bg-white p-6 rounded-md shadow-sm '>
    <h1 class=' text-2xl font-bold text-black'>{{ form_title|default('Informations générales') }}</h1>
    <p class='text-gray-500'>{{ form_label|default('') }}</p>
    {{ form_start(form) }}
    <div class='flex flex-col gap-4'>
        <div class='flex w-full '>
            <div class='flex w-1/2 '>
                {{ form_label(form.client) }}
            </div>
            <div class='flex w-1/2 px-10'>
                {{ form_label(form.created_at) }}
                
            </div>
        </div>
        <div class='flex gap-2 w-full '>
            {{ form_widget(form.client, {attr: {class: ' w-full h-10 mb-2 p-2 border rounded-md border-gray-200 rounded-md'}}) }}
            {{ form_errors(form.client) }}
            <a href="{{ path('app_client_new') }}"class='w-1/9 inline-flex items-center justify-center text-blue-500 hover:text-blue-700 h-10 border rounded-md border-gray-200 '>
                {{ ux_icon('lucide:plus') }}
            </a>
            {{ form_widget(form.created_at, {attr: {class: ' w-full h-10 mb-2 p-2 border rounded-md border-gray-200 rounded-md'}}) }}
            {{ form_errors(form.created_at) }}
        </div>
    </div> 
</div>

<div class='flex flex-col gap-2 bg-white p-6 rounded-md shadow-sm'>
    <div>
        <p>aqui va le formulaire pour les produits</p>
    </div>

</div>
    
    
    
    
    
    <div class='flex gap-4 mt-6 justify-end'>
        <button class="btn bg-white text-black border border-gray-200 h-10 p-2 rounded-md">
            <a href="{{ path('app_invoice_index') }}">Annuler</a>
        </button>
        <button  type="submit" class="btn btn bg-blue-500 text-white h-10 p-2 rounded-md">
            {{ button_label|default('Enregistrer') }}
        </button>
    </div>
    {{ form_end(form) }}

