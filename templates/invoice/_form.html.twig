<div class='flex flex-col gap-2 bg-white p-6 rounded-md shadow-sm '>
	<h2 class=' text-2xl font-bold text-black'>{{ form_title|default('Informations générales') }}</h2>
	<p class='text-gray-500'>{{ form_label|default('') }}</p>
	{{ form_start(form) }}
	<div class='flex flex-col gap-4'>
		<div class='flex w-full gap-2'>

			<div class='flex flex-col w-1/2 '>
				{{ form_label(form.client) }}
				{{ form_widget(form.client, {attr: {class: ' w-full h-10 mb-2 p-2 border rounded-md border-gray-200 rounded-md'}}) }}
				{{ form_errors(form.client) }}
			</div>

			<div class='flex mt-6 w-auto h-10 px-4 border rounded-md border-gray-200 items-center justify-center'>
				<a href="{{ path('app_client_new') }}" class="  text-blue-500 hover:text-blue-700">
					{{ ux_icon('lucide:plus') }}
				</a>
			</div>

			<div class='flex flex-col w-1/2'>
				<p class="text-gray-600">Date de la facture: </p>
                <p class="w-full h-10 mb-2 p-2 border rounded-md border-gray-200">{{ invoice.createdAt|date("d/m/Y") }}</p>
            </div>
		</div>
	</div>
</div>

<div class='flex gap-4 mt-6 mb-6 justify-end'>
	<button class="btn bg-white text-black border border-gray-200 h-10 p-2 rounded-md">
		<a href="{{ path('app_invoice_index') }}">Annuler</a>
	</button>
	<button type="submit" class="btn btn bg-blue-500 text-white h-10 p-2 rounded-md">
		{{ button_label|default('Enregistrer') }}
	</button>
</div>
<div class='flex flex-col gap-2 bg-white p-6 rounded-md shadow-sm'>
    <div>
        <h2 class='border-b-2 border-black text-2xl font-bold text-black'>Lignes de la facture</h2>
    </div> 
    <div class="border border-gray-200 rounded-md py-4 bg-white shadow-sm w-full overflow-x-auto">
		<table class="table-auto w-full">
			<thead class='border-b border-gray-200'>
				<tr>
					<th class='px-4 py-2 text-left'>Nom</th>
					<th class='px-4 py-2 text-left'>Description</th>
					<th class='px-4 py-2 text-left'>Prix unitaire</th>
					<th class='px-4 py-2 text-left'>Actions</th>
				</tr>
			</thead>
			<tbody>
				{% for product in this.getAllProducts() %}
					<tr>
						<td class='px-4 py-2 align-middle'>{{ product.name }}</td>
						<td class='px-4 py-2 align-middle'>{{ product.description }}</td>
						<td class='px-4 py-2 align-middle'>{{ product.price }}€/{{ product.unit.value }}</td>

						<td class='flex gap-4 px-4 mt-1 py-2 align-middle whitespace-nowrap'>
							<a href="{{ path('app_product_edit', {'id': product.id}) }}"
							 class="text-blue-500 mt-1 hover:text-blue-700">{{ ux_icon('lucide:edit-2') }}</a>
							<form method="post" action="{{ path('app_product_delete', {'id': product.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                <button class="btn text-red-500 hover:text-red-700">{{ ux_icon('lucide:trash-2') }}</button>
                            </form>
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="4">no records found</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>

{{ form_end(form) }}
