<div class='flex flex-col gap-2 bg-white p-6 rounded-md shadow-sm'>
<h1 class=' text-2xl font-bold text-black'>{{ form_title|default('Nouveau produit') }}</h1>
<p class='text-gray-500'>{{ form_label|default('') }}</p>
{{ form_start(form) }}
    {{ form_label(form.name) }}
	{{ form_widget(form.name, {attr: {class: 'w-full h-10 mb-2 border rounded-md border-gray-200 rounded-md'}}) }}
	{{ form_errors(form.name) }}

    {{ form_label(form.description) }}
	{{ form_widget(form.description, {attr: {class: ' w-full h-20 mb-2 border rounded-md border-gray-200 rounded-md'}}) }}
	{{ form_errors(form.description) }}

    <div class='flex gap-1'>
        <div class='flex flex-col w-1/2'>
            {{ form_label(form.price) }}
            {{ form_widget(form.price, {attr: {class: ' w-full h-10 mb-2 border rounded-md border-gray-200 rounded-md'}}) }}
            {{ form_errors(form.price) }}
        </div>
        <div class='flex flex-col w-1/2'>
            {{ form_label(form.unit) }}
            {{ form_widget(form.unit, {attr: {class: ' w-full h-10 mb-2 border rounded-md border-gray-200 rounded-md'}}) }}
            {{ form_errors(form.unit) }}
        </div>
    </div>
    
    <div class='flex gap-4 mt-6 justify-end'>
        <button class="btn bg-white text-black border border-gray-200 h-10 p-2 rounded-md">
            <a href="{{ path('app_product_index') }}">Annuler</a>
        </button>
        <button  type="submit" class="btn btn bg-blue-500 text-white h-10 p-2 rounded-md">
            {{ button_label|default('Enregistrer') }}
        </button>
    </div>
{{ form_end(form) }}
</div>
